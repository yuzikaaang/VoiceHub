{
  "name": "voicehub",
  "version": "1.5.8.4",
  "description": "校园广播站点歌管理系统 - 基于数据库存储的现代化点歌、排期和播放管理平台",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "type": "module",
  "scripts": {
    "build": "node --max-old-space-size=6144 ./node_modules/nuxt/bin/nuxt.mjs build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "db:migrate": "pnpm exec drizzle-kit migrate",
    "db:generate": "pnpm exec drizzle-kit generate --name=auto-migration",
    "db:push": "pnpm exec drizzle-kit push --force",
    "db:studio": "pnpm exec drizzle-kit studio",
    "db:drop": "pnpm exec drizzle-kit drop",
    "db:check": "pnpm exec drizzle-kit check",
    "setup": "pnpm install --frozen-lockfile && pnpm run db:migrate",
    "create-admin": "pnpm exec tsx scripts/create-admin.js",
    "clear-db": "pnpm exec tsx scripts/clear-database.js",
    "safe-migrate": "pnpm exec tsx scripts/safe-migrate.js",
    "deploy": "node scripts/deploy.js",
    "vercel-build": "node scripts/deploy.js",
    "netlify-build": "node scripts/netlify-build.js",
    "check-deploy": "node scripts/check-deploy.js",
    "postinstall": "nuxt prepare && node scripts/postinstall.js",
    "lint": "nuxt prepare && eslint .",
    "lint:fix": "nuxt prepare && eslint . --fix",
    "format": "prettier --write .",
    "init-help": "pnpm run db:push && pnpm run create-admin"
  },
  "dependencies": {
    "@applemusic-like-lyrics/core": "^0.5.1",
    "@applemusic-like-lyrics/lyric": "^0.3.0",
    "@applemusic-like-lyrics/vue": "^0.5.1",
    "@breezystack/lamejs": "^1.2.7",
    "@lucide/vue": "^1.21.0",
    "@neteasecloudmusicapienhanced/api": "^4.36.1",
    "@netlify/functions": "^2.8.2",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pixi/app": "^7.4.3",
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "@pixi/filter-blur": "^7.4.3",
    "@pixi/filter-bulge-pinch": "^5.1.1",
    "@pixi/filter-color-matrix": "^7.4.3",
    "@pixi/sprite": "^7.4.3",
    "@sansenjian/qq-music-api": "2.4.0",
    "@sentry/node": "^10.62.0",
    "@sentry/vue": "^10.62.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash-es": "^4.17.12",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@ungap/structured-clone": "^1.3.2",
    "@vercel/speed-insights": "^1.3.1",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "bezier-easing": "^2.1.0",
    "chalk": "^5.6.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.21",
    "deep-freeze": "^0.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "formidable": "^3.5.4",
    "gl-matrix": "4.0.0-beta.2",
    "html-to-image": "^1.11.13",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lodash-es": "^4.18.1",
    "multer": "^2.2.0",
    "nodemailer": "^8.0.11",
    "nuxt": "^4.4.8",
    "otplib": "^12.0.1",
    "postgres": "^3.4.9",
    "prompts": "^2.4.2",
    "qrcode": "^1.5.4",
    "redis": "^5.12.1",
    "sass": "^1.101.0",
    "svg-captcha": "^1.4.0",
    "tsx": "^4.22.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4",
    "wasm-media-encoders": "^0.7.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18.20.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "eslint": "^9.39.4",
    "prettier": "^3.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@applemusic-like-lyrics/core",
      "@applemusic-like-lyrics/lyric",
      "@applemusic-like-lyrics/vue",
      "@parcel/watcher",
      "@swc/core",
      "core-js",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
